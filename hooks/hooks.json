{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/bin/on-work.js\"",
            "timeout": 30,
            "statusMessage": "Updating usage monitor"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/bin/on-stop.js\"",
            "async": false
          }
        ]
      }
    ]
  }
}
